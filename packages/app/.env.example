# opencode serve 后端地址（开发模式）
VITE_OPENCODE_SERVER_HOST=localhost
VITE_OPENCODE_SERVER_PORT=4096

# COS 发布 CLI 脚本路径（opencode serve 所在机器上的绝对路径）
VITE_DEPLOY_CLI_SCRIPT=D:/opencodewebui_v0/opencode-ui/packages/deploy-server/src/cli.ts

# 可选：Chromium 安装目录（默认从 CLI 路径推导为 packages/deploy-server/browsers）
# VITE_PLAYWRIGHT_BROWSERS_PATH=D:/opencodewebui_v0/opencode-ui/packages/deploy-server/browsers
